MainTab:CreateToggle({
   Name = "Auto-Merge Loop",
   CurrentValue = false,
   Callback = function(Value)
      _G.AutoMerge = Value
      task.spawn(function()
          while _G.AutoMerge do
             local merged = runMergeProcess()
             task.wait(merged and 3 or 5)
          end
      end)
   end,
})

MainTab:CreateButton({
