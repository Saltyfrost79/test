        Rayfield:Notify({Title = "Scanning", Content = "Checking all spawns...", Duration = 3})
        
        for _, loc in pairs(DB_LOCATIONS) do
            char:PivotTo(loc)
            task.wait(0.5)
            if sniperDragonBall() then 
