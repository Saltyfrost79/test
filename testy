local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

-- Services
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TeleportService = game:GetService("TeleportService")
local HttpService = game:GetService("HttpService")
local Players = game:GetService("Players")
local LP = Players.LocalPlayer

-- ==========================================
-- CONFIGURATION
-- ==========================================
local MERGE_CFRAME = CFrame.new(229.45134, -181.306137, 183.051865)
local BOSS_SPAWN_CFRAME = CFrame.new(-255.015045, -5.69940853, -881.5802) 

local BossList = {"Aizen (Hogyoku)", "All For One", "Boros", "Dio Over Heaven", "Fusion Zamasu (Corrupted)", "Heian Era Sukuna", "Madara Ten Tails", "Meliodas (Demon Form 2)", "Mob"}
local Blacklist = {["Wano Luffy"] = true, ["Naru (Kid)"] = true}

-- ==========================================
-- SHARED STATE
-- ==========================================
_G.InBattle = false
_G.SnipingNow = false

-- ==========================================
-- RECOVERY & UTILITIES
-- ==========================================

local function equipMainSquad()
    local args = {
        [1] = {
            ["1"] = "Toji",
            ["4"] = "Titan Rengoku",
            ["3"] = "Mega Sparking Hakari",
            ["2"] = "Mahito"
        }
    }
    ReplicatedStorage.Events.SquadUpdate:FireServer(unpack(args))
end

-- ==========================================
-- MERGE LOGIC (STANDALONE)
-- ==========================================
local function standaloneMerge()
    if _G.InBattle or _G.SnipingNow then return false end
    
    local inventory = LP:FindFirstChild("DoodleInv")
    local targetUnit = nil
    if inventory then
        for _, item in pairs(inventory:GetChildren()) do
            if item.Value >= 4 and not Blacklist[item.Name] then
                targetUnit = item.Name
                break
            end
        end
    end

    if targetUnit then
        LP.Character:PivotTo(MERGE_CFRAME)
        task.wait(1)
        local squadArgs = {[1] = {["1"] = targetUnit, ["2"] = targetUnit, ["3"] = targetUnit, ["4"] = targetUnit}}
        ReplicatedStorage.Events.SquadUpdate:FireServer(unpack(squadArgs))
        task.wait(0.8)
        local prompt = workspace:FindFirstChild("Prompt", true) 
        if prompt then fireproximityprompt(prompt) end
        return true
    end
    return false
end

-- ==========================================
-- RAID CONTROLLER (WITH BUILT-IN MERGE/RECOVERY)
-- ==========================================
local function raidController()
    if _G.InBattle then return end
    
    local campaign = workspace:FindFirstChild("Campaign")
    local activeBoss = nil
    for _, name in pairs(BossList) do
        if campaign and campaign:FindFirstChild(name) then
            activeBoss = campaign[name]
            break
        end
    end

    if activeBoss then
        _G.InBattle = true
        LP.Character:PivotTo(BOSS_SPAWN_CFRAME)
        task.wait(0.5)
        ReplicatedStorage.Events.RequestBattle:FireServer(activeBoss)
        
        task.spawn(function()
            while campaign:FindFirstChild(activeBoss.Name) do task.wait(1) end
            _G.InBattle = false
        end)
    else
        -- RAID SPREE MERGE: Merge + Force Squad Reset
        local merged = standaloneMerge()
        if merged then
            task.wait(1.5)
            equipMainSquad()
            task.wait(1)
        end
        
        -- Return to watch for spawns
        if (LP.Character.HumanoidRootPart.Position - BOSS_SPAWN_CFRAME.Position).Magnitude > 10 then
            LP.Character:PivotTo(BOSS_SPAWN_CFRAME)
        end
    end
end

