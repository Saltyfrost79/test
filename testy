local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local LP = Players.LocalPlayer

local Window = Rayfield:CreateWindow({
   Name = "AniPixels | Average Hub",
   LoadingTitle = "Delta Interface",
   LoadingSubtitle = "by Average",
   ConfigurationSaving = { Enabled = false }
})

local MainTab = Window:CreateTab("Automation")

-- CONFIGURATION
local MERGE_CFRAME = CFrame.new(227.596115, -180.579788, 182.112259, 0, 0, 1, 0, 1, -0, -1, 0, 0)
local TP_THRESHOLD = 15 -- Distance in studs; if further than this, it will TP

-- Helper to find the prompt
local function getMergePrompt()
    return workspace:FindFirstChild("Prompt", true) 
end

-- Core Logic Function
local function runMergeProcess()
    local char = LP.Character or LP.CharacterAdded:Wait()
    local root = char:WaitForChild("HumanoidRootPart")
    local inventory = LP:WaitForChild("DoodleInv")
    local targetUnit = nil

    -- 1. Check for stack of 4+
    for _, item in pairs(inventory:GetChildren()) do
        if item.Value >= 4 then
            targetUnit = item.Name
            break
        end
    end

    if targetUnit then
        -- 2. SMART TELEPORT: Only TP if you are too far away
        local distance = (root.Position - MERGE_CFRAME.Position).Magnitude
        if distance > TP_THRESHOLD then
            print("Too far from station. Teleporting...")
            char:PivotTo(MERGE_CFRAME)
            ReplicatedStorage.Events.Teleport:FireServer(MERGE_CFRAME)
            task.wait(1.2)
        end

        -- 3. EQUIP SQUAD
        local squadArgs = {[1] = {["1"] = targetUnit, ["2"] = targetUnit, ["3"] = targetUnit, ["4"] = targetUnit}}
        ReplicatedStorage.Events.SquadUpdate:FireServer(unpack(squadArgs))
        task.wait(0.8)

        -- 4. TRIGGER MERGE
        local prompt = getMergePrompt()
        if prompt then
            fireproximityprompt(prompt)
            Rayfield:Notify({Title = "Merged", Content = "Successfully processed: " .. targetUnit, Duration = 2})
            return true -- Success
        else
            Rayfield:Notify({Title = "Error", Content = "Prompt not in range!", Duration = 3})
        end
    else
        return false -- Nothing found
    end
end

-- UI BUTTONS
MainTab:CreateButton({
   Name = "Manual Merge (Single)",
   Callback = function()
      local success = runMergeProcess()
      if not success then
          Rayfield:Notify({Title = "Notice", Content = "Nothing found to merge.", Duration = 2})
      end
   end,
})

MainTab:CreateToggle({
   Name = "Auto-Merge Loop",
   CurrentValue = false,
   Callback = function(Value)
      _G.AutoMerge = Value
      task.spawn(function()
          while _G.AutoMerge do
             local merged = runMergeProcess()
             if not merged then
                 -- If nothing was found, wait a bit longer before checking again
                 task.wait(5) 
             else
                 -- Wait for the game's animation/cooldown
                 task.wait(3) 
             end
          end
      end)
   end,
})
