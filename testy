-- ==========================================
local function getMergePrompt()
    return workspace:FindFirstChild("Prompt", true) 
end

-- ==========================================
-- DRAGON BALL SNIPER LOGIC
-- ==========================================
local function sniperDragonBall()
    local char = LP.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    
    -- Search for the ball object
    local ball = workspace:FindFirstChild("Dragon Ball", true) or workspace:FindFirstChild("DragonBall", true)

    if ball and not _G.SnipingNow then
        _G.SnipingNow = true -- Prevent double-firing
        local prompt = ball:FindFirstChildOfClass("ProximityPrompt") or ball:FindFirstChild("Prompt", true)
        
        if prompt then
            local originalPos = char.HumanoidRootPart.CFrame
            
            -- 1. Stealth TP In
            char:PivotTo(ball.CFrame)
            task.wait(0.2) 

            -- 2. Collect
            fireproximityprompt(prompt)
            
            -- 3. Stealth TP Out
            task.wait(0.2) 
            char:PivotTo(originalPos)
            
            Rayfield:Notify({Title = "Sniper", Content = "Dragon Ball Collected!", Duration = 5})
        end
        task.wait(2) -- Wait for ball to despawn
        _G.SnipingNow = false
    end
end

-- ==========================================
-- MERGER LOGIC
-- ==========================================
local function runMergeProcess()
    local char = LP.Character or LP.CharacterAdded:Wait()
    local root = char:WaitForChild("HumanoidRootPart")
    local inventory = LP:WaitForChild("DoodleInv")
    local targetUnit = nil

    for _, item in pairs(inventory:GetChildren()) do
        if item.Value >= 4 and not Blacklist[item.Name] then
            targetUnit = item.Name
            break
        end
    end

    if targetUnit then
        local distance = (root.Position - MERGE_CFRAME.Position).Magnitude
        if distance > TP_THRESHOLD then
            char:PivotTo(MERGE_CFRAME)
            ReplicatedStorage.Events.Teleport:FireServer(MERGE_CFRAME)
            task.wait(1.2)
        end

        local squadArgs = {[1] = {["1"] = targetUnit, ["2"] = targetUnit, ["3"] = targetUnit, ["4"] = targetUnit}}
        ReplicatedStorage.Events.SquadUpdate:FireServer(unpack(squadArgs))
        task.wait(0.8)

        local prompt = getMergePrompt()
        if prompt then
            fireproximityprompt(prompt)
            return true 
        end
    end
    return false
end

