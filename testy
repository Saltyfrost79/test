local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local LP = Players.LocalPlayer

local Window = Rayfield:CreateWindow({
   Name = "AniPixels | Average Hub",
   LoadingTitle = "Delta Interface",
   LoadingSubtitle = "by Average",
   ConfigurationSaving = { Enabled = false }
})

local MainTab = Window:CreateTab("Automation")

local function runMergeProcess()
    local inventory = LP:WaitForChild("DoodleInv")
    local targetUnit = nil

    -- 1. Check for a stack of 4
    for _, item in pairs(inventory:GetChildren()) do
        if item.Value >= 4 then
            targetUnit = item.Name
            break
        end
    end

    if targetUnit then
        -- 2. Teleport
        local tpPos = CFrame.new(311.89, 34.42, -190.07) * CFrame.Angles(0, 1.57, 0)
        LP.Character:PivotTo(tpPos)
        ReplicatedStorage.Events.Teleport:FireServer(tpPos)
        task.wait(1.5)

        -- 3. Equip 4 from the stack
        -- Since they stack, the server usually expects the same name 4 times
        local squadArgs = {
            [1] = {
                ["1"] = targetUnit,
                ["2"] = targetUnit,
                ["3"] = targetUnit,
                ["4"] = targetUnit
            }
        }
        ReplicatedStorage.Events.SquadUpdate:FireServer(unpack(squadArgs))
        task.wait(1)

        -- 4. Fire Merge
        local remote = workspace:FindFirstChild("RemoteEvent", true)
        if remote then
            remote:FireServer()
            Rayfield:Notify({Title = "Success", Content = "Merged stack of " .. targetUnit, Duration = 3})
        end
    else
        Rayfield:Notify({Title = "Error", Content = "No stacks of 4 found!", Duration = 3})
    end
end

MainTab:CreateToggle({
   Name = "Auto-Merge Stacks",
   CurrentValue = false,
   Callback = function(Value)
      _G.AutoMerge = Value
      task.spawn(function()
          while _G.AutoMerge do
             runMergeProcess()
             task.wait(10)
          end
      end)
   end,
})
